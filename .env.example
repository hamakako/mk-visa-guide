# Create a file named .env.local and paste your private Gemini API key there.
GEMINI_API_KEY=

# Strong, fast model with Google Search grounding support.
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite

# Free-mode controls: reserve two daily requests and cache successful answers for seven days.
FREE_DAILY_AI_LIMIT=18
VISA_CACHE_TTL_HOURS=168
